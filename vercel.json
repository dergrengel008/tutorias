{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "@vercel/php"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_URL": "",
        "APP_KEY": "",
        "DB_CONNECTION": "pgsql",
        "DB_HOST": "",
        "DB_PORT": "5432",
        "DB_DATABASE": "",
        "DB_USERNAME": "",
        "DB_PASSWORD": "",
        "DB_SSLMODE": "require",
        "SESSION_DRIVER": "database",
        "CACHE_DRIVER": "database",
        "VIEW_COMPILED_PATH": "/tmp/storage/framework/views"
    }
}
